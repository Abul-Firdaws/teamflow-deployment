# Frontend Environment Variables — Production Template
# Copy this file to .env.production and fill in your actual values.
# NEVER commit .env.production with real values to version control.

# Option 1: Direct EC2 connection (HTTP only — causes Mixed Content on HTTPS)
# VITE_API_URL=http://YOUR_EC2_PUBLIC_IP:5000/api

# Option 2: CloudFront API proxy (Recommended — full HTTPS)
VITE_API_URL=https://YOUR_CLOUDFRONT_DOMAIN/api

